{
	"name": "@portfolio/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"generate-schema-idx": "tsx scripts/generate-schema-idx.ts",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate && pnpm generate-schema-idx",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "tsx src/migrate.ts",
		"db:seed": "tsx src/seed.ts"
	},
	"dependencies": {
		"@libsql/client": "^0.15.4",
		"@portfolio/env": "workspace:*",
		"argon2": "^0.44.0",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.1",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@portfolio/config": "workspace:*",
		"drizzle-kit": "^0.31.8",
		"tsx": "^4.22.4",
		"typescript": "catalog:"
	}
}